{
  "compatibility_date": "2026-05-09",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "danchambers-dev",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "danchambers.dev",
      "custom_domain": true,
    },
  ],
}
